<div class="section-header">
  <h1>✏️ Edit Job</h1>
  <p>Update the job listing details.</p>
</div>

<div class="form-container">
  <%= form_with(model: [@company, @job], local: true) do |form| %>
    <div class="form-group">
      <%= form.label :title %>
      <%= form.text_field :title, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :location %>
      <%= form.text_field :location, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :job_type %>
      <%= form.text_field :job_type, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :description %>
      <%= form.text_area :description, rows: 6, class: "form-input" %>
    </div>

    <div class="form-actions">
      <%= form.submit " Update Job", class: "submit-btn" %>
    </div>
  <% end %>
</div>
