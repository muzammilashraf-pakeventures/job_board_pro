<!-- app/views/companies/new.html.erb -->
<div class="section-header">
  <h1>🏢 New Company</h1>
  <p>Create a new company record.</p>
</div>

<div class="form-container">
  <%= form_with model: @company, local: true do |form| %>
    <div class="form-group">
      <%= form.label :name %>
      <%= form.text_field :name, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :location %>
      <%= form.text_field :location, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :website %>
      <%= form.text_field :website, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :description %>
      <%= form.text_area :description, class: "form-input", rows: 5 %>
    </div>

    <div class="form-actions">
      <%= form.submit "🚀 Create Company", class: "submit-btn" %>
    </div>
  <% end %>
</div>
