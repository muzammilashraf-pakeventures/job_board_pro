<div class="section-header">
  <h1>✏️ Edit Company</h1>
  <p>Update company details below.</p>
</div>

<div class="form-container">
  <%= form_with(model: @company, local: true) do |form| %>
    <div class="form-group">
      <%= form.label :name %>
      <%= form.text_field :name, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :location %>
      <%= form.text_field :location, class: "form-input" %>
    </div>

    <div class="form-group">
      <%= form.label :description %>
      <%= form.text_area :description, rows: 5, class: "form-input" %>
    </div>

    <div class="form-actions">
      <%= form.submit " Update Company", class: "submit-btn" %>
    </div>
  <% end %>
</div>
